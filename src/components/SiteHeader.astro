---
import { useTranslations } from "@/lib/useTranslations";

const { lang = "en" } = Astro.props;
const t = useTranslations(lang);
const isIt = lang === "it";

const LOGO = "/images/Logo-marysszang.png";
const base = isIt ? "/it/marysszang/" : "/marysszang/";
const contactsHref = isIt ? "/it/contatti" : "/contacts";
const homeHref = isIt ? "/it/" : "/";
const langSwitchHref = isIt ? "/marysszang/" : "/it/marysszang/";
---

<header class="msz-header">
  <div class="msz-header__bar">
    <a href={base} class="msz-header__brand" aria-label="Marysszang">
      <img src={LOGO} alt="marysszang" />
    </a>

    <nav class="msz-desktop-nav" aria-label="Primary">
      <a href={`${base}#artworks`}>{t.nav.artworks}</a>
      <a href={`${base}#about`}>{t.nav.aboutMarysszang}</a>
      <a href={`${base}#collaborations`}>{t.nav.collaborations}</a>
      <span class="divider" aria-hidden="true"></span>
      <a href={contactsHref} class="msz-chip-btn">{t.nav.contacts}</a>
      <a href={homeHref} class="pill pill--dark">{t.nav.brandBoutique}</a>
      <a href={langSwitchHref}>{isIt ? "EN" : "IT"}</a>
    </nav>

    <button id="mszHamburger" class="msz-hamburger" aria-label="Open menu" aria-expanded="false">
      <span class="bar"></span>
      <span class="bar"></span>
      <span class="bar"></span>
    </button>
  </div>

  <div id="mszMobilePanel" class="msz-menu">
    <span class="msz-menu__diamond" aria-hidden="true"></span>
    <nav class="msz-menu__nav">
      <a href={`${base}#artworks`}>{t.nav.artworks}</a>
      <a href={`${base}#about`}>{t.nav.aboutMarysszang}</a>
      <a href={`${base}#collaborations`}>{t.nav.collaborations}</a>
      <a href={contactsHref}>{t.nav.contacts}</a>
      <a href={homeHref} class="pill pill--dark msz-menu__cta">{t.nav.brandBoutique}</a>
      <a href={langSwitchHref}>{isIt ? "EN" : "IT"}</a>
    </nav>
  </div>

  <script is:inline>
    (() => {
      const btn = document.getElementById('mszHamburger');
      const panel = document.getElementById('mszMobilePanel');
      if (!btn || !panel) return;

      let open = false;
      const setOpen = (state) => {
        open = state;
        btn.setAttribute('aria-expanded', open ? 'true' : 'false');
        btn.classList.toggle('is-open', open);
        panel.classList.toggle('is-open', open);
        document.documentElement.classList.toggle('msz-no-scroll', open);
      };

      btn.addEventListener('click', () => setOpen(!open));
      document.addEventListener('keydown', (e) => e.key === 'Escape' && open && setOpen(false));
      panel.addEventListener('click', (e) => {
        if (e.target.closest('a')) setOpen(false);
      });
    })();
  </script>
</header>