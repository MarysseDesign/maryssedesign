---
import { useTranslations } from "@/lib/useTranslations";
import { getLangFromUrl } from "@/lib/i18n";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const label = t.ui.goToTop.toUpperCase();
---

<button
  aria-label={t.ui.goToTop}
  class="go-to-top js-go-to-top"
>
  {label}
</button>

<style>
/* lascia tutto il tuo CSS invariato */
.go-to-top {
  position: fixed;
  right: 16px;
  bottom: 60px;
  padding: 10px 19px;
  border-radius: 999px;
  background: #fff;
  color: #111;
  font-family: inherit;
  font-size: 10px;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  border-width: 1px;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 60;
  opacity: 0;
  transform: translateY(12px);
  pointer-events: none;
  transition: opacity .25s ease, transform .25s ease;
}

@media (max-width: 768px) {
  .go-to-top.is-visible {
    opacity: .75;
    transform: translateY(0);
    pointer-events: auto;
  }
}

.go-to-top.is-active {
  opacity: 1 !important;
}

.go-to-top:active {
  transform: translateY(2px);
}

@media (hover: hover) {
  .go-to-top.is-visible:hover {
    opacity: 1;
  }
}
</style>

<script is:inline>
(() => {
  const btn = document.querySelector('.js-go-to-top');
  if (!btn) return;

  let activeTimeout;

  const toggleVisibility = () => {
    if (window.scrollY > 300) btn.classList.add('is-visible');
    else btn.classList.remove('is-visible');
  };

  const setActive = () => {
    btn.classList.add('is-active');
    clearTimeout(activeTimeout);
    activeTimeout = setTimeout(() => {
      btn.classList.remove('is-active');
    }, 900);
  };

  btn.addEventListener('pointerdown', setActive);
  btn.addEventListener('click', () => {
    setActive();
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });

  window.addEventListener('scroll', toggleVisibility, { passive: true });
  toggleVisibility();
})();
</script>