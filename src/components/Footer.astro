---
import { useTranslations } from "@/lib/useTranslations";

const { lang = "en" } = Astro.props;
const t = useTranslations(lang);
const isIt = lang === "it";

const privacyHref = isIt ? "/it/privacy" : "/privacy";
const cookiesHref = isIt ? "/it/cookie-policy" : "/cookie-policy";
---

<footer class="border-t border-black/20 mt-0 pt-2 md:pt-4 pb-10 md:pb-16 font-montserrat uppercase tracking-[2px] text-[#191118]">
  <div class="container mx-auto max-w-screen-xl text-center text-[9px] md:text-[10px]">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-10 mt-7 md:gap-0 md:items-center">
      <div class="space-y-3">
        <h6 class="leading-relaxed opacity-60">{t.footer.instagram}</h6>

        <div class="space-y-2">
          <a
            href="https://www.instagram.com/maryssedesign/"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 hover:opacity-70 transition-opacity"
          >
            <span class="opacity-60">{t.footer.brandBoutique}</span>
            <span class="underline underline-offset-4 decoration-black/20">@maryssedesign</span>
          </a>

          <a
            href="https://www.instagram.com/marysszang/"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 hover:opacity-70 transition-opacity"
          >
            <span class="opacity-60">{t.footer.artisticSide}</span>
            <span class="underline underline-offset-4 decoration-black/20">@marysszang</span>
          </a>
        </div>
      </div>

      <div>
        <h6 class="leading-relaxed" set:html={t.footer.location.replace('\n', '<br/>')} />
      </div>

      <div>
        <h6 class="leading-relaxed">
          <a
            href="mailto:info@maryssedesign.com?subject=Info%20request"
            class="hover:opacity-70 transition-opacity underline underline-offset-4 decoration-black/20"
          >
            info@maryssedesign.com
          </a>
          <br />
          + 39 346 6600169
        </h6>
      </div>

      <div class="space-y-3">
        <h6 class="leading-relaxed opacity-60">{t.footer.elsewhere}</h6>

        <div class="flex items-center justify-center gap-4">
          <a
            href="https://www.behance.net/marysse93"
            target="_blank"
            rel="noopener noreferrer"
            class="underline underline-offset-4 decoration-black/20"
          >
            Behance
          </a>

          <a
            href="https://it.linkedin.com/in/marysse"
            target="_blank"
            rel="noopener noreferrer"
            class="underline underline-offset-4 decoration-black/20"
          >
            LinkedIn
          </a>
        </div>

        <p class="opacity-40 leading-relaxed">{t.footer.updating}</p>
      </div>
    </div>
  </div>
</footer>

<footer class="bg-[#191118] pt-12 pb-12 font-montserrat uppercase tracking-[2px] text-[#a5a0a5]">
  <div class="container mx-auto max-w-screen-xl">
    <div class="text-center text-[9px] md:text-[10px] space-y-5">
      <div>
        <img src="/images/Marysse_logo_footer.png" alt="Marysse Logo" class="mx-auto max-w-[180px] logofootbottom" />
      </div>
      <div class="font-light">{t.footer.by}</div>
      <div class="font-light">{t.footer.rights}</div>
      <div class="font-light">
        <a href={privacyHref} class="text-[#f4f2f4] hover:opacity-70">{t.footer.privacy}</a>
        <span class="mx-2">|</span>
        <a href={cookiesHref} class="text-[#f4f2f4] hover:opacity-70">{t.footer.cookies}</a>
      </div>
    </div>
  </div>
</footer>