---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import ProjectsGrid from "@/components/ProjectsGrid.jsx";

const ALL_CATEGORIES = [
  "All",
  "Fashion & Luxury",
  "Corporate & Innovation",
  "Retail & Hospitality",
  "Professional Services",
  "Big Brands",
];

const projects = await getCollection("projects", ({ data }) => data.lang === "en");

const items = projects
  .map((p) => ({
    slug: p.data.translationKey,
    ordine: p.data.ordine ?? 999,
    titolo: p.data.titolo,
    abstract: p.data.abstract ?? "",
    cover: p.data.cover,
    meta: [p.data.cliente, p.data.anno].filter(Boolean).join(" • "),
    badges: p.data.badges ?? [],
    categories: p.data.categories ?? [],
  }))
  .sort((a, b) => a.ordine - b.ordine);
---

<BaseLayout 
title="Projects · Marysse Design" 
description="A curated selection of projects by Marysse Design, across brand identity, retail experiences, campaigns and digital design."
lang="en">
  <main class="projects-page">
    <header class="projects-hero">
      <div class="projects-center">
        <div class="projects-hero__inner">
          <h1 class="projects-title page-fade" style="--d: 80ms;">Projects</h1>

          <p class="projects-subtitle">
            Simple ideas, carefully crafted.<br />
            Design is strongest when it says only what is needed.
          </p>
        </div>
      </div>
    </header>

    <div class="projects-center page-fade" style="--d: 320ms;">
      <ProjectsGrid client:load items={items} categories={ALL_CATEGORIES} lang="en" />
    </div>

    <style>
      /* ==========================================================
        Layout / centering
      ========================================================== */

      .projects-page {
        padding-top: 40px;
        padding-bottom: 80px;
        padding-left: 0 !important;
        padding-right: 0 !important;
      }

      .projects-center {
        width: 100%;
        display: flex;
        justify-content: center;
      }

      .projects-hero {
        text-align: center;
        width: 100%;
      }

      .projects-hero__inner {
        width: min(980px, 52vw);
        text-align: center;
        position: relative;
      }

      .projects-title,
      .projects-subtitle {
        margin-left: auto !important;
        margin-right: auto !important;
      }

      .projects-title {
        margin: 0;
        font-family: "Noto Serif Display", serif;
        font-weight: 300;
        font-size: clamp(40px, 5.2vw, 78px);
        line-height: 1.02;
        color: #111;
      }

    .projects-subtitle {
  margin: 14px auto 0;
  font-size: 16px;
  line-height: 1.85;
  font-weight: 300;
  color: rgba(25, 17, 24, 0.82);
  max-width: 70ch;
}

      /* Grid container (React root) */
      :global(.projects) {
        width: min(1100px, 94vw);
        margin: 0 !important; /* ci pensa il flex wrapper */
      }

      /* ==========================================================
        Filters + Grid
      ========================================================== */

      :global(.projects__filters) {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 10px;
        padding: 14px 0 26px;
      }

      :global(.filter-chip) {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 9px 14px;
        border-radius: 999px;
        border: 1px solid rgba(0, 0, 0, 0.14);
        background: rgba(255, 255, 255, 0.7);
        color: rgba(13, 13, 13, 0.78);
        font-size: 11px;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        transition: transform 0.15s ease, border-color 0.15s ease, background 0.15s ease;
        cursor: pointer;
        user-select: none;
      }

      :global(.filter-chip:hover) {
        transform: translateY(-1px);
        border-color: rgba(0, 0, 0, 0.28);
        background: rgba(255, 255, 255, 0.92);
      }

      :global(.filter-chip__dot) {
        width: 6px;
        height: 6px;
        border-radius: 999px;
        background: rgba(0, 0, 0, 0.22);
      }

      :global(.filter-chip.is-active) {
        border-color: rgba(0, 0, 0, 0.38);
        background: rgba(0, 0, 0, 0.03);
        color: rgba(12, 12, 12, 0.98);
      }

      :global(.filter-chip.is-active .filter-chip__dot) {
        background: rgba(0, 0, 0, 0.75);
      }

      :global(.projects__grid) {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 18px;
        align-items: start;
        padding-top: 6px;
      }

      @media (max-width: 840px) {
        .projects-title { font-size: 44px; }
        :global(.projects__grid) { grid-template-columns: 1fr; }
        .spark { display: none; }
      }

      /* ==========================================================
        Card (rendered by React)
      ========================================================== */
 /* ==========================================================
  Card (rendered by React) — SOBER / ABOUT-CONSISTENT
========================================================== */

:global(.p-card) {
  display: block;
  border-radius: 24px; /* più sobrio di 42, ma non “UI standard” */
  overflow: hidden;
  border: 1px solid rgba(25, 17, 24, 0.12); /* hairline in stile About */
  background: rgba(255, 255, 255, 0.86);    /* soft, premium */
  text-decoration: none;
  color: inherit;
  transition: transform 180ms ease, box-shadow 180ms ease, border-color 180ms ease;
  box-shadow: 0 10px 28px rgba(25, 17, 24, 0.06); /* più “editorial” */
}

:global(.p-card:hover) {
  transform: translateY(-2px);
  border-color: rgba(25, 17, 24, 0.18);
  box-shadow: 0 16px 44px rgba(25, 17, 24, 0.10);
}

/* Se hai un wrapper media, lo arrotondiamo sopra */
:global(.p-card__media) {
  border-radius: 24px 24px 0 0;
  overflow: hidden;
}

:global(.p-card__media img) {
  display: block;
  width: 100%;
  height: auto;
  object-fit: cover;
}

:global(.p-card__body) {
  padding: 16px 18px 18px;
}

/* Titolo: serif light come About, ma senza “tarot line” e senza eccessi */
:global(.p-card__title) {
  margin: 0;
  font-family: "Noto Serif Display", serif;
  font-weight: 300;
  font-size: 18px;
  line-height: 1.18;
  letter-spacing: -0.01em;
  color: rgba(25, 17, 24, 0.92);
}

/* Abstract: stesso “respiro” di About (weight 300, line-height alto) */
:global(.p-card__abstract) {
  margin: 10px 0 0;
  font-size: 14px;
  font-weight: 300;
  line-height: 1.7;
  color: rgba(25, 17, 24, 0.76);
}

/* Meta: understated, uppercase come i kicker */
:global(.p-card__meta) {
  margin: 10px 0 0;
  font-size: 11px;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: rgba(25, 17, 24, 0.52);
}

:global(.p-card__badges) {
  margin-top: 12px;
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

/* Badge: più “About-like”, ma sobrio */
:global(.p-badge) {
  font-size: 10px;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  padding: 7px 11px;
  border-radius: 999px;
  border: 1px solid rgba(25, 17, 24, 0.12);
  color: rgba(25, 17, 24, 0.62);
  background: rgba(255, 255, 255, 0.65);
}




      /* ==========================================================
  Mobile compact header spacing
========================================================== */
@media (max-width: 640px) {

.projects-hero {
    text-align: center;
    margin: 10px auto 40px;
    max-width: 760px;
}

.projects-hero__inner {
   padding-top: 20px !important;
}
  .projects-page {
    padding-top: 20px !important;
    padding-bottom: 40px !important;
  }

  /* header più compatto */
  .projects-hero__inner {
    width: min(980px, 92vw);
  }

  /* titolo: un filo più piccolo + meno spazio sotto */
  .projects-title {
    font-size: 40px;     /* prima 44px (già a 840px) */
    line-height: 1.05;
    margin-bottom: 8px;
  }

  /* sottotitolo: meno margini */
  .projects-subtitle {
    margin: 10px auto 10px; /* prima 18px auto 18px */
    font-size: 15px;
    line-height: 1.55;
  }

  /* filtri: meno padding sopra/sotto */
  :global(.projects__filters) {
    padding: 10px 0 16px;   /* prima 14px 0 26px */
    gap: 8px;
  }

  /* opzionale: chip leggermente più piccoli su mobile */
  :global(.filter-chip) {
    padding: 8px 12px;
    font-size: 10px;
  }
}

/* ===============================
   Go to top – cookie style
================================ */
.go-to-top {
  position: fixed;
  right: 16px;
  bottom: 60px;
  padding: 10px 19px;
  border-radius: 999px;
  background: #fff;
  color: #111;
  font-family: inherit;
  font-size: 10px;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  border-width: 1px;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 60;

  /* stato nascosto */
  opacity: 0;
  transform: translateY(12px);
  pointer-events: none;

  transition:
    opacity .25s ease,
    transform .25s ease;
}

/* visibile (solo mobile) */
@media (max-width: 768px) {
  .go-to-top.is-visible {
    opacity: .75; /* semi-trasparente */
    transform: translateY(0);
    pointer-events: auto;
  }
}

/* stato attivo (tap) */
.go-to-top.is-active {
  opacity: 1 !important;
}

/* feedback tap */
.go-to-top:active {
  transform: translateY(2px);
}

/* hover su device che lo supportano */
@media (hover: hover) {
  .go-to-top.is-visible:hover {
    opacity: 1;
  }
}

 </style>
  </main>
</BaseLayout>


<button id="goToTop" aria-label="Go to top" class="go-to-top">
  GO TO TOP
</button>


<script is:inline>
  (() => {
    const btn = document.getElementById('goToTop');
    if (!btn) return;

    const toggle = () => {
      if (window.scrollY > 300) {
        btn.classList.add('is-visible');
      } else {
        btn.classList.remove('is-visible');
      }
    };

    btn.addEventListener('click', () => {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });

    window.addEventListener('scroll', toggle, { passive: true });
    toggle();
  })();
</script>
