---
import BaseLayout from "@/layouts/BaseLayout.astro";
import GoToTop from "@/components/GoToTop.astro";
import { getCollection } from "astro:content";
import "@/styles/legacy-project.css";
import "@/styles/badges.css";
import "@/styles/legacy-project-templates.css";

export async function getStaticPaths() {
  const projects = await getCollection("projects");
  return projects.map((p) => ({
    params: { slug: p.slug },
    props: { project: p },
  }));
}

const { project } = Astro.props;
const { Content } = await project.render();

// ✅ Template:
// Default: "legacy" (così tutto continua a funzionare anche senza template)
const template = (project.data.template ?? "legacy").toString().toLowerCase();

// ✅ Helper: slugify rapido per anchors/URL (usato per future estensioni, non rompe nulla)
const slugify = (s = "") =>
  s
    .toString()
    .trim()
    .toLowerCase()
    .replace(/&/g, "and")
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/^-+|-+$/g, "");

// ✅ (Opzionale) se vuoi usare i badge come link ai filtri della pagina /projects
// useremo un hash tipo /projects#cat=fashion-luxury oppure /projects#badge=art-direction
const badgeToFilterHref = (badge) => `/projects#badge=${encodeURIComponent(slugify(badge))}`;
const categoryToFilterHref = (cat) => `/projects#cat=${encodeURIComponent(slugify(cat))}`;

// ✅ Flag (se un domani vuoi spegnere divider su un template)
const showDivider = project.data.showDivider !== false;
---

<BaseLayout
  title={`${project.data.titolo} — Projects`}
  description={project.data.abstract ?? "Project case study."}
  brand="marysse"
>
  <main class={`project-page template-${template}`}>
    <!-- HERO -->
    <section class="hero text-center">
      <div class="container">
        <div class="row">
          <div class="col-md-8 col-md-offset-2">

            <h1 class="reveal" data-delay="0">{project.data.titolo}</h1>

            {project.data.sottotitolo && (
              <div class="project-meta reveal" data-delay="120" set:html={project.data.sottotitolo} />
            )}

            {project.data.badges?.length ? (
              <div class="badge-row reveal" data-delay="220" aria-label="Project roles">
                {project.data.badges.map((b) => (
                  <span class="badge" title={b}>
                    {b}
                  </span>
                ))}
              </div>
            ) : null}

            {project.data.intro && (
              <p class="introduction reveal" data-delay="320" set:html={project.data.intro} />
            )}

            {/* Divider verticale */}
            {showDivider ? <div class="divider-vertical reveal" data-delay="420" aria-hidden="true" /> : null}

          </div>
        </div>
      </div>
    </section>

    <!-- CONTENT -->
    <section class="content text-center">
      <div class="container content-container">
        <article class="prose">
          <Content />
        </article>
      </div>

      <!-- ✅ GO TO TOP (mobile only) -->
      <GoToTop />

         <!-- PAGINATION -->
      <div class="container">
        <div class="row mt-xl">
          <div class="col-md-12">
            <div class="pagination" aria-label="Project navigation">
              {project.data.prevSlug ? (
                <a
                  class="nav-circle"
                  href={`/projects/${project.data.prevSlug}/`}
                  aria-label="Previous project"
                >
                  <span class="nav-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" width="18" height="18" fill="none">
                      <path
                        d="M14.5 5.5L8 12l6.5 6.5"
                        stroke="currentColor"
                        stroke-width="1.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      />
                    </svg>
                  </span>
                </a>
              ) : (
                <span class="nav-circle is-disabled" aria-hidden="true">
                  <span class="nav-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" width="18" height="18" fill="none">
                      <path
                        d="M14.5 5.5L8 12l6.5 6.5"
                        stroke="currentColor"
                        stroke-width="1.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      />
                    </svg>
                  </span>
                </span>
              )}

              <a class="nav-pill" href="/projects">
                Back
              </a>

              {project.data.nextSlug ? (
                <a
                  class="nav-circle"
                  href={`/projects/${project.data.nextSlug}/`}
                  aria-label="Next project"
                >
                  <span class="nav-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" width="18" height="18" fill="none">
                      <path
                        d="M9.5 5.5L16 12l-6.5 6.5"
                        stroke="currentColor"
                        stroke-width="1.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      />
                    </svg>
                  </span>
                </a>
              ) : (
                <span class="nav-circle is-disabled" aria-hidden="true">
                  <span class="nav-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" width="18" height="18" fill="none">
                      <path
                        d="M9.5 5.5L16 12l-6.5 6.5"
                        stroke="currentColor"
                        stroke-width="1.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      />
                    </svg>
                  </span>
                </span>
              )}
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
<script src="/scripts/site.js" defer></script>
</BaseLayout>
