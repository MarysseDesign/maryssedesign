---
import BaseLayout from "@/layouts/BaseLayout.astro";
import GoToTop from "@/components/GoToTop.astro";
import { getCollection } from "astro:content";
import "@/styles/legacy-project.css";
import "@/styles/badges.css";
import "@/styles/legacy-project-templates.css";

export async function getStaticPaths() {
  const projects = await getCollection("projects", ({ data }) => data.lang === "it");

  return projects.map((p) => ({
    params: { slug: p.data.translationKey },
    props: { project: p },
  }));
}

const { project } = Astro.props;
const { Content } = await project.render();

const template = (project.data.template ?? "legacy").toString().toLowerCase();

const showDivider = project.data.showDivider !== false;
---

<BaseLayout
  title={`${project.data.titolo} · Marysse Design`}
  description={project.data.abstract ?? "Case study di progetto."}
  brand="marysse"
  lang="it"
>
  <main class={`project-page template-${template}`}>
    <section class="hero text-center">
      <div class="container">
        <div class="row">
          <div class="col-md-8 col-md-offset-2">
            <h1 class="reveal" data-delay="0">{project.data.titolo}</h1>

            {project.data.sottotitolo && (
              <div class="project-meta reveal" data-delay="120" set:html={project.data.sottotitolo} />
            )}

            {project.data.badges?.length ? (
              <div class="badge-row reveal" data-delay="220" aria-label="Ruoli del progetto">
                {project.data.badges.map((b) => (
                  <span class="badge" title={b}>
                    {b}
                  </span>
                ))}
              </div>
            ) : null}

            {project.data.intro && (
              <p class="introduction reveal" data-delay="320" set:html={project.data.intro} />
            )}

            {showDivider ? <div class="divider-vertical reveal" data-delay="420" aria-hidden="true" /> : null}
          </div>
        </div>
      </div>
    </section>

    <section class="content text-center">
      <div class="container content-container">
        <article class="prose">
          <Content />
        </article>
      </div>

      <GoToTop />

      <div class="container">
        <div class="row mt-xl">
          <div class="col-md-12">
            <div class="pagination" aria-label="Navigazione progetti">
              {project.data.prevSlug ? (
                <a
                  class="nav-circle"
                  href={`/it/progetti/${project.data.prevSlug}/`}
                  aria-label="Progetto precedente"
                >
                  <span class="nav-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" width="18" height="18" fill="none">
                      <path
                        d="M14.5 5.5L8 12l6.5 6.5"
                        stroke="currentColor"
                        stroke-width="1.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      />
                    </svg>
                  </span>
                </a>
              ) : (
                <span class="nav-circle is-disabled" aria-hidden="true">
                  <span class="nav-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" width="18" height="18" fill="none">
                      <path
                        d="M14.5 5.5L8 12l6.5 6.5"
                        stroke="currentColor"
                        stroke-width="1.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      />
                    </svg>
                  </span>
                </span>
              )}

              <a class="nav-pill" href="/it/progetti">
                Indietro
              </a>

              {project.data.nextSlug ? (
                <a
                  class="nav-circle"
                  href={`/it/progetti/${project.data.nextSlug}/`}
                  aria-label="Progetto successivo"
                >
                  <span class="nav-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" width="18" height="18" fill="none">
                      <path
                        d="M9.5 5.5L16 12l-6.5 6.5"
                        stroke="currentColor"
                        stroke-width="1.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      />
                    </svg>
                  </span>
                </a>
              ) : (
                <span class="nav-circle is-disabled" aria-hidden="true">
                  <span class="nav-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" width="18" height="18" fill="none">
                      <path
                        d="M9.5 5.5L16 12l-6.5 6.5"
                        stroke="currentColor"
                        stroke-width="1.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      />
                    </svg>
                  </span>
                </span>
              )}
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <script src="/scripts/site.js" defer></script>
</BaseLayout>