---
import BaseLayout from "@/layouts/BaseLayout.astro";
import "@/styles/services-dark-tarot.css";


const tarotServices = [
  {
    key: "branding",
    number: "I",
    title: "Branding",
    archetype: "La Firma",
    subtitle: "Identità e Posizionamento",
    img: "/images/tarot/branding.jpg",
    desc:
"Identità visive pensate per rendere i brand unici, riconoscibili, coerenti e inevitabili in ogni punto di contatto.",
  },
  {
    key: "strategy",
    number: "II",
    title: "Direzione Creativa",
    archetype: "La Visione",
    subtitle: "Strategia e Concept Creativo",
    img: "/images/tarot/strategy.jpg",
    desc:
"Scelte creative che danno forma a visione e significato, allineando strategia, concept ed espressione in un sistema coerente.",
 },
  {
    key: "advertising",
    number: "III",
    title: "Advertising",
    archetype: "L’Allure",
    subtitle: "Campagne e Art Direction",
    img: "/images/tarot/advertising.jpg",
    desc:
"Campagne guidate da un’art direction precisa, dove ogni elemento contribuisce a costruire valore e desiderabilità.",
  },
  {
    key: "web",
    number: "IV",
    title: "Web Design",
    archetype: "Il Portale",
    subtitle: "Esperienze Digitali Luxury",
    img: "/images/tarot/web.jpg",
    desc:
"Esperienze digitali progettate con precisione e sensibilità, dove struttura, tipografia e movimento risultano naturali e impeccabili.",
      
  },
  {
    key: "storytelling",
    number: "V",
    title: "Storytelling",
    archetype: "La Voce",
    subtitle: "Narrazione e Voce del Brand",
    img: "/images/tarot/storytelling.jpg",
    desc:
"Narrazioni intenzionali, capaci di dare voce al marchio con carattere e restare rilevanti nel tempo.",
  },
  {
    key: "social",
    number: "VI",
    title: "Social Media",
    archetype: "Il Ritmo",
    subtitle: "Contenuti e Ritmo Editoriale",
    img: "/images/tarot/social.jpg",
   desc:
"Una presenza digitale costruita con coerenza e direzione, dove contenuto, ritmo e immagine parlano all’unisono.",
      
  },
  {
    key: "visual",
    number: "VII",
    title: "Sistema Visivo",
    archetype: "Il Codice",
    subtitle: "Linee Guida e Linguaggio di Design",
    img: "/images/tarot/visual.jpg",
   desc:
"Un sistema visivo che stabilisce regole, struttura e linguaggio progettuale, pensato per evolvere insieme al brand.",
      
  },
  {
    key: "photo",
    number: "VIII",
    title: "Fotografia",
    archetype: "Lo Sguardo",
    subtitle: "Immagini di Prodotto e di Brand",
    img: "/images/tarot/photo.jpg",
    desc:
"Immagini guidate dall’art direction, pensate per essere coerenti, elevate e perfettamente intenzionali.",
  },
  {
    key: "video",
    number: "IX",
    title: "Video",
    archetype: "Il Movimento",
    subtitle: "Motion e Brand Film",
    img: "/images/tarot/video.jpg",
    desc:
"Contenuti video e motion sviluppati con sensibilità cinematografica, tra narrazione e costruzione dell’immaginario.",
      
  },
  {
    key: "events",
    number: "X",
    title: "Experiential",
    archetype: "L’Incontro",
    subtitle: "Eventi e Brand Moments",
    img: "/images/tarot/events.jpg",
    desc:
      "Esperienze di brand costruite attraverso identità, visual e direzione, per tradurre il marchio in una presenza fisica riconoscibile.",
  },
];

const collaborations = [
  { name: "Armani", src: "/images/collaborations/armani-beauty-logo.png" },
  { name: "Rinascente", src: "/images/collaborations/rinascente-logo.png" },
  { name: "Mondadori", src: "/images/collaborations/mondadori-logo.png" },
  { name: "Campari Academy", src: "/images/collaborations/campari-academy-logo.png" },
  { name: "Terrazza Aperol", src: "/images/collaborations/terrazza-aperol-logo.png" },
  { name: "Berlucchi Franciacorta", src: "/images/collaborations/berlucchi-logo.png" },
  { name: "The Wom", src: "/images/collaborations/the-wom-logo.png" },
  { name: "My Personal Trainer", src: "/images/collaborations/my-personal-trainer-logo.png" },
  { name: "My Personal Beauty", src: "/images/collaborations/my-personal-beauty-logo.png" },
  { name: "L'Oreal", src: "/images/collaborations/loreal-logo.png" },
  { name: "Pupa", src: "/images/collaborations/pupa-logo.png" },
  { name: "Primolino", src: "/images/collaborations/primolino-logo.png" },
];

const selectedWorks = [
  {
    title: "Armani × Rinascente",
    category: "Retail Experience / Art Direction",
    href: "/it/progetti/armani-rinascente/",
    image: "/images/projects/covers/home_Armani_Rinascente.jpg",
    alt: "Cover del progetto Armani Rinascente",
  },
  {
    title: "Campari Academy",
    category: "Brand Experience / Campaign",
    href: "/it/progetti/campari/",
    image: "/images/projects/covers/03.png",
    alt: "Cover del progetto Campari Academy",
  },
  {
    title: "Primolino Milano",
    category: "Brand Identity / Packaging",
    href: "/it/progetti/primolino/",
    image: "/images/projects/covers/11.Primolino.jpg",
    alt: "Cover del progetto Primolino",
