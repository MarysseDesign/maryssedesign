---
import BaseLayout from "@/layouts/BaseLayout.astro";

const HERO_IMG_DESKTOP = "/images/hero-desktop.jpg";
const HERO_IMG_MOBILE = "/images/hero-mobile.jpg";

const iconImages = {
  boutique: "/images/about/icons/boutique.jpg",
  identity: "/images/about/icons/identity.jpg",
  digital: "/images/about/icons/digital.jpg",
};
---

<BaseLayout 
brand="marysse" 
title="About · Marysse Design" 
description="Scopri l’approccio di Marysse Design: una direzione creativa indipendente che costruisce identità, immagini e sistemi di brand per posizionamenti premium e luxury."
noMainBottomPadding={true} 
footerVariant="minimal">
  <head slot="head">
    <link rel="preload" as="image" href={HERO_IMG_DESKTOP} />
    <link rel="preload" as="image" href={HERO_IMG_MOBILE} media="(max-width: 768px)" />
  </head>

  <section class="relative h-screen w-full overflow-hidden -mt-20">
    <picture class="absolute inset-0">
      <source srcset={HERO_IMG_MOBILE} media="(max-width: 768px)" />
      <img
        src={HERO_IMG_DESKTOP}
        alt=""
        class="w-full h-full object-cover"
        loading="eager"
        decoding="async"
      />
    </picture>

    <div class="absolute inset-0 z-10 pointer-events-none"></div>

    <div class="hero-inner relative z-20 flex h-full items-center">
      <div class="site-container pb-14 md:pb-16">
     <div class="hero-copy max-w-xl text-white">
 <h1 class="hero-title text-5xl md:text-7xl">
  <span class="hero-desktop-copy">La boutique agency <br />per brand memorabili.</span>
  <span class="hero-mobile-copy">Per brand memorabili.</span>
</h1>

<p class="about-leadwhite opacity-100">
  <span class="hero-desktop-copy">
    Marysse Design affianca brand e realtà imprenditoriali nella costruzione di un’immagine chiara, coerente e distintiva.
    <br />
    Dall’identità visiva alla presenza digitale, ogni progetto nasce per valorizzare ciò che rende un brand riconoscibile, credibile e desiderabile.
  </span>

  <span class="hero-mobile-copy">
    Diamo forma a brand e realtà imprenditoriali, costruendo un’immagine chiara, <br class="show-mobile" />coerente e distintiva.
  </span>
</p>

  <div class="mt-10 hero-cta flex flex-wrap gap-3">
    <a href="/it/servizi/" class="cta-light">
      <span class="hero-desktop-copy">SCOPRI IL METODO</span>
      <span class="hero-mobile-copy">SCOPRI COME</span>
    </a>
  </div>
</div>
      </div>
    </div>

    <div class="absolute inset-x-0 bottom-0 z-30 h-11 md:h-14">
      <div class="marquee-overlay"></div>
      <div class="relative h-full w-full overflow-hidden leading-none flex items-center">
        <div class="whitespace-nowrap animate-marquee uppercase tracking-wide text-[13px] md:text-sm">
          <span class="mx-8">ADVERTISING</span><span class="mx-8">·</span>
          <span class="mx-8">BRANDING</span><span class="mx-8">·</span>
          <span class="mx-8">WEB DESIGN</span><span class="mx-8">·</span>
          <span class="mx-8">SOCIAL MEDIA</span><span class="mx-8">·</span>
          <span class="mx-8">VISUAL DESIGN</span><span class="mx-8">·</span>
          <span class="mx-8">CREATIVE CONCEPT</span><span class="mx-8">·</span>
          <span class="mx-8">PHOTOGRAPHY</span><span class="mx-8">·</span>
          <span class="mx-8">VIDEO</span><span class="mx-8">·</span>
          <span class="mx-8">EVENTS</span><span class="mx-8">·</span>
          <span class="mx-8"><strong>MARYSSE DESIGN</strong></span><span class="mx-8">·</span>

          <span class="mx-8">ADVERTISING</span><span class="mx-8">·</span>
          <span class="mx-8">BRANDING</span><span class="mx-8">·</span>
          <span class="mx-8">WEB DESIGN</span><span class="mx-8">·</span>
          <span class="mx-8">SOCIAL MEDIA</span><span class="mx-8">·</span>
          <span class="mx-8">VISUAL DESIGN</span><span class="mx-8">·</span>
          <span class="mx-8">CREATIVE CONCEPT</span><span class="mx-8">·</span>
          <span class="mx-8">PHOTOGRAPHY</span><span class="mx-8">·</span>
          <span class="mx-8">VIDEO</span><span class="mx-8">·</span>
          <span class="mx-8">EVENTS</span><span class="mx-8">·</span>
          <span class="mx-8"><strong>MARYSSE DESIGN</strong></span><span class="mx-8">·</span>
        </div>
      </div>
    </div>
  </section>

  <div class="about-page">
    <section class="about-section about-light" aria-label="Panoramica su Marysse Design">
      <div class="site-container about-inner">
        <div class="about-top">
          <div class="reveal" style="--delay: 80ms">
            <p class="about-kicker">About Marysse Design<br class="show-mobile" /><br class="show-mobile" /></p>
            
            <h2 class="about-title">
  Uno studio boutique per costruire <br class="hide-mobile" /> brand solidi, distintivi e ben posizionati.<br class="show-mobile" /><br class="show-mobile" />
</h2>
            <br class="hide-mobile" />
           <p class="about-lead">
  Marysse Design è uno studio creativo indipendente fondato e diretto da <br class="show-mobile" />Maria Assunta Zangone.
  <br /><br class="show-mobile" />
  Si occupa di identità di marca, direzione creativa, campagne ed <br class="hide-mobile" />esperienze digitali per<br class="show-mobile" /> brand premium e luxury.
  <br class="hide-mobile" /><br/>
  Ogni progetto nasce da una visione chiara: <br class="hide-mobile" />dare al brand una presenza riconoscibile, coerente e di valore.
</p>

<p class="about-lead">
  Il lavoro si sviluppa attraverso <br class="show-mobile" />tre aree principali: <br class="show-mobile" />posizionamento, identità ed esperienza.
</p>
          </div>
        </div>

        <div class="about-cards">
          <article class="about-card tarot-min reveal" style="--delay: 140ms">
            <figure class="about-media" aria-hidden="true">
              <img src={iconImages.boutique} alt="" width="1200" height="1500" loading="lazy" decoding="async" />
            </figure>

            <div class="tarot-content">
             <h3>Posizionamento</h3>
<p>
  Definiamo con chiarezza chi è il brand, <br class="hide-mobile" /> cosa lo distingue
 
  e come deve essere  <br class="hide-mobile" />percepito dal suo pubblico.
</p>

              <div class="tarot-items">
                <span class="tarot-item">Strategia di Marca</span>
                <span class="tarot-item">Tone of voice</span>
                <span class="tarot-item">Principi Guida</span>
              </div>
            </div>
          </article>

          <article class="about-card tarot-min reveal" style="--delay: 200ms">
            <figure class="about-media" aria-hidden="true">
              <img src={iconImages.identity} alt="" width="1200" height="1500" loading="lazy" decoding="async" />
            </figure>

            <div class="tarot-content">
              <h3>Identità</h3>
<p>
  Costruiamo un’immagine visiva coerente, <br class="hide-mobile" />elegante e riconoscibile,
  
  capace di rappresentare il brand in ogni contesto.
</p>

              <div class="tarot-items">
                <span class="tarot-item">Art Direction</span>
                <span class="tarot-item">Identità Visiva</span>
                <span class="tarot-item">Design System</span>
              </div>
            </div>
          </article>

          <article class="about-card tarot-min reveal" style="--delay: 260ms">
            <figure class="about-media" aria-hidden="true">
              <img src={iconImages.digital} alt="" width="1200" height="1500" loading="lazy" decoding="async" />
            </figure>

            <div class="tarot-content">
             <h3>Esperienze</h3>
<p>
  Portiamo il brand nei suoi spazi di relazione:
  <br class="hide-mobile" />
  sito, contenuti, campagne e  <br class="hide-mobile" />materiali di comunicazione.
</p>

              <div class="tarot-items">
                <span class="tarot-item">Web Design</span>
                <span class="tarot-item">Campagne</span>
                <span class="tarot-item">Direzione Contenuti</span>
              </div>
            </div>
          </article>
        </div>
      </div>
    </section>

    <section class="about-section about-veil" aria-label="Visione">
      <div class="site-container about-inner">
        <div class="about-grid">
          <header class="about-head reveal" style="--delay: 80ms">
            <p class="about-kicker">Visione</p>
           <h2 class="about-title">
  Un brand forte nasce da una visione chiara e coerente.
</h2>
            <p class="about-lead"><br class="show-mobile" />
  Un brand premium non si costruisce sommando elementi scollegati,
  ma mantenendo una direzione precisa nel tempo.
  <br class="show-mobile" />
  Il nostro lavoro è creare coerenza tra immagine, linguaggio e presenza digitale,
  affinché il brand risulti naturale, autorevole e immediatamente riconoscibile.
</p>
          </header>

          <div class="about-body">
            <div class="about-miniGrid">
              <div class="about-mini reveal" style="--delay: 140ms">
               <h4>Prima viene la chiarezza</h4>
<p>
  Ogni scelta funziona meglio quando <br class="hide-mobile" />il brand ha una direzione precisa
  <br class="hide-mobile" />
  e una struttura ben definita.
</p>
              </div>

              <div class="about-mini2 reveal" style="--delay: 200ms">
                <h4>La coerenza crea fiducia</h4>
<p>
  Quando tutto parla la stessa lingua, <br class="hide-mobile" />il brand appare più solido,
  <br class="hide-mobile" />
  credibile e memorabile.
</p>
              </div>

              <div class="about-mini reveal" style="--delay: 260ms">
               <h4>Lo stile deve durare</h4>
<p>
  L’eleganza non segue la moda del <br class="hide-mobile" />momento:
  nasce da misura,<br class="hide-mobile" /> precisione e continuità.
</p>
              </div>
            </div>
          </div>

          <p class="about-lead">
  Un brand di valore cresce quando ogni dettaglio è coerente con la sua identità.
<br class="show-mobile" />
          </p>
        </div>
      </div>
    </section>

    <section class="about-section about-light about-collab" aria-label="Metodo">
      <div class="site-container about-inner">
        <div class="about-grid">
          <header class="about-head reveal" style="--delay: 80ms">
            <p class="about-kicker">Metodo</p>
            <h2 class="about-title">Un metodo curato, flessibile e su misura.<br class="show-mobile" /><br class="show-mobile" /></h2>
           <p class="about-lead">
  Marysse Design lavora attraverso una direzione creativa unitaria.
  <br class="hide-mobile" />
  In base al progetto, vengono coinvolti collaboratori e specialisti selezionati,
  mantenendo sempre una visione chiara, coerente e sotto controllo.
</p>
          </header>

          <div class="about-body">
            <div class="about-miniGrid two">
              <div class="about-mini2 reveal" style="--delay: 140ms">
               <h4>Struttura dello studio</h4>
<p>
  Una realtà agile e ben organizzata, capace di adattarsi alle esigenze del brand
  senza perdere qualità, attenzione e coerenza.
</p>
              </div>

              <div class="about-mini reveal" style="--delay: 200ms">
                <h4>Una sola direzione</h4>
<p>
  Ogni progetto segue una guida creativa precisa,
  così che immagine, contenuti e presenza digitale risultino allineati.
</p>
              </div>
            </div>

            <div class="about-signature reveal" style="--delay: 240ms">
              <div class="signature-inner">
                <div class="signature-image">
                  <img src="/images/about/marysse-portrait.jpg" alt="Maria Assunta Zangone" />
                </div>

                <div class="signature-content">
                  <p class="about-kicker">Firma</p>

                  <p class="about-lead">
  Marysse Design nasce da una sensibilità che unisce visione estetica e chiarezza strategica.
</p>

<p class="about-lead">
  Ogni progetto viene seguito con una direzione precisa,
  per costruire brand coerenti, riconoscibili e ben posizionati.
</p>

<p class="about-lead">
  L’obiettivo è dare forma a sistemi di marca completi,
  in cui immagine, linguaggio e presenza lavorano insieme in modo armonico.
</p>

                  <p class="signature-caption">
                    Maria Assunta Zangone <br />
                    Founder & Creative Director
                  </p>
                </div>
              </div>
            </div>

            <div class="about-split reveal" style="--delay: 260ms">
              <div>
                <p class="about-kicker">Best fit</p>
                <h3 class="about-subtitle">Per brand che vogliono distinguersi con chiarezza e valore.</h3>
              </div>
              <ul class="about-list">
                <li>Posizionamenti premium e luxury</li>
                <li>Founder e team di brand</li>
                <li>Nuovi lanci o evoluzioni di marca</li>
                <li>Team attenti al dettaglio e alla coerenza</li>
              </ul>
            </div>

            <div class="about-actions reveal" style="--delay: 320ms">
              <a href="/it/progetti/" class="cta-dark">ESPLORA I PROGETTI</a>
              <a href="/it/marysszang/" class="cta-ghost-dark">SCOPRI IL LATO ARTISTICO DI MARYSSE</a>
            </div>
          </div>
        </div>
      </div>
    </section>
  </div>

  <style is:global>
    .about-page {
      background: #fff;
      --box-border-color: #e5e7eb;
      --box-border-width: 1px;
      --stroke-color: rgba(25, 17, 24, 0.12);
      --stroke-width: 0.4px;
    }

    .about-section {
      position: relative;
      padding: clamp(54px, 7vw, 92px) 0;
      text-align: center;
    }

    .about-inner {
      position: relative;
    }

    :root {
      --about-sky-1: #e5edf4;
      --about-sky-2: #c1d3e2;
      --about-sky-3: #b2c7d8;
      --about-blush-1: #d2c4ce;
      --about-lav-1: #aeb0c3;
      --about-deep-1: #4f7f9c;
      --about-blue-1: #bccae2;
    }

    .about-light {
      background:
        radial-gradient(
          900px 520px at 70% 85%,
          color-mix(in srgb, var(--about-blush-1) 45%, transparent),
          transparent 70%
        ),
        linear-gradient(
          180deg,
          #ffffff 0%,
          #ffffff 55%,
          color-mix(in srgb, var(--about-sky-3) 18%, #ffffff) 100%
        );
    }

    .about-veil {
      background:
        radial-gradient(
          980px 520px at 35% 440%,
          color-mix(in srgb, var(--about-sky-2) 82%, transparent),
          transparent 100%
        ),
        radial-gradient(
          980px 520px at 65% 90%,
          color-mix(in srgb, var(--about-blue-1) 28%, transparent),
          transparent 100%
        ),
        linear-gradient(180deg, #fbfbfb 0%, #ffffff 100%);
    }

    .about-kicker {
      margin: 0 0 12px;
      font-size: 11px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: rgba(25, 17, 24, 0.62);
    }

    .about-title {
      margin: 0;
      font-family: "Noto Serif Display", serif;
      font-weight: 300;
      letter-spacing: -0.02em;
      line-height: 1.06;
      font-size: clamp(34px, 4.8vw, 58px);
      color: var(--ink);
    }

    .about-subtitle {
      margin: 0;
      font-family: "Noto Serif Display", serif;
      font-weight: 300;
      letter-spacing: -0.02em;
      line-height: 1.12;
      font-size: clamp(22px, 2.4vw, 28px);
      color: var(--ink);
    }

    .about-lead {
      margin: 14px auto 0;
      font-size: 16px;
      line-height: 1.85;
      font-weight: 300;
      color: rgba(25, 17, 24, 0.82);
      max-width: 78ch;
    }

    .about-leadwhite {
      margin: 14px auto 0;
      padding-top: 14px;
      font-size: 16px;
      line-height: 1.85;
      font-weight: 300;
      color: rgba(255, 255, 255, 0.82);
      max-width: 70ch;
    }

    .about-top {
      max-width: 1120px;
      margin: 0 auto;
    }

    .about-grid {
      display: grid;
      grid-template-columns: 0.95fr 1.05fr;
      gap: clamp(24px, 4vw, 56px);
      align-items: start;
      max-width: 1120px;
      margin: 0 auto;
      text-align: center;
    }

    .about-veil .about-grid {
      grid-template-columns: 1fr;
      max-width: 980px;
    }

    .about-cards {
      margin-top: 26px;
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 14px;
      max-width: 1120px;
      margin-left: auto;
      margin-right: auto;
    }

    .about-card,
    .about-mini,
    .about-mini2,
    .about-split {
      border: var(--box-border-width) solid var(--box-border-color);
    }

    .tarot-min {
      position: relative;
      border-radius: 42px;
      background: rgba(255, 255, 255, 0.72);
      box-shadow: 0 14px 40px rgba(25, 17, 24, 0.08);
      overflow: hidden;
      text-align: center;
      padding: 0;
    }

    @media (hover: hover) {
      .tarot-min {
        transition:
          transform 180ms ease,
          box-shadow 180ms ease,
          border-color 180ms ease;
      }

      .tarot-min:hover {
        transform: translateY(-2px);
        box-shadow: 0 18px 52px rgba(25, 17, 24, 0.1);
        border-color: rgba(25, 17, 24, 0.18);
      }
    }

    .about-media {
      margin: 0;
      width: 100%;
      border: 0;
      border-radius: 42px 42px 0 0;
      overflow: hidden;
      background: rgba(255, 255, 255, 0.75);
      aspect-ratio: 1 / 1;
    }

    .about-media img {
      width: 100%;
      height: 100%;
      display: block;
      object-fit: cover;
      filter: saturate(0.95) contrast(1.02);
    }

    .tarot-content {
      padding: 18px 22px 18px;
    }

    .tarot-min h3 {
      margin: 2px 0 10px;
      font-family: "Noto Serif Display", serif;
      font-weight: 300;
      font-size: 22px;
      letter-spacing: -0.01em;
      color: var(--ink);
    }

    .tarot-min h3::after {
      content: "";
      display: block;
      width: 46px;
      height: 1px;
      margin: 12px auto 0;
      background: rgba(25, 17, 24, 0.1);
    }

    .tarot-min p {
      margin: 0 auto;
      max-width: 42ch;
      opacity: 0.9;
      color: rgba(25, 17, 24, 0.78);
      font-weight: 300;
      line-height: 1.7;
      font-size: 14px;
    }

    .tarot-items {
      margin-top: 16px;
      display: grid;
      gap: 8px;
      max-width: 260px;
      margin-left: auto;
      margin-right: auto;
    }

    .tarot-item {
      display: block;
      padding: 8px 12px;
      border-radius: 30px;
      border: 1px solid #e5e7eb;
      background: rgba(255, 255, 255, 0.55);
      font-size: 12.5px;
      line-height: 1.4;
      letter-spacing: 0.04em;
      text-align: center;
      color: rgba(25, 17, 24, 0.78);
    }

    .about-miniGrid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 12px;
      justify-items: center;
    }

    .about-miniGrid.two {
      grid-template-columns: repeat(2, 1fr);
    }

    .about-mini {
      border-end-end-radius: 42px;
      border-top-left-radius: 42px;
      padding: 18px 16px;
      background: rgba(255, 255, 255, 0.65);
      backdrop-filter: blur(8px);
      text-align: center;
      width: 100%;
    }

    .about-mini2 {
      border-end-start-radius: 42px;
      border-top-right-radius: 42px;
      padding: 18px 16px;
      background: rgba(255, 255, 255, 0.65);
      backdrop-filter: blur(8px);
      text-align: center;
      width: 100%;
    }

    .about-mini h4,
    .about-mini2 h4 {
      margin: 8px 0 10px;
      font-weight: 400;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      font-size: 12px;
      color: var(--ink);
    }

    .about-mini p,
    .about-mini2 p {
      margin: 0;
      font-size: 13.5px;
      line-height: 1.75;
      font-weight: 300;
      color: rgba(25, 17, 24, 0.78);
    }

    .about-split {
      margin-top: 18px;
      display: grid;
      grid-template-columns: 1fr;
      gap: 14px;
      align-items: start;
      border-radius: 18px;
      padding: 16px;
      background: rgba(255, 255, 255, 0.55);
      backdrop-filter: blur(8px);
      text-align: center;
    }

    .about-list {
      margin: 0;
      padding-left: 0;
      list-style-position: inside;
      color: rgba(25, 17, 24, 0.78);
      font-size: 14px;
      line-height: 1.9;
      font-weight: 300;
      text-align: center;
    }

    .about-actions {
      margin-top: 18px;
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      justify-content: center;
    }

    .cta-ghost-dark {
      display: inline-block;
      padding: 12px 18px;
      border-radius: 999px;
      font-size: 12px;
      font-weight: 300;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      border: 1px solid var(--hairline);
      color: var(--ink);
      background: rgba(255, 255, 255, 0.6);
      backdrop-filter: blur(6px);
      text-decoration: none !important;
      transition:
        opacity 0.2s ease,
        border-color 0.2s ease,
        transform 0.2s ease;
    }

    .cta-ghost-dark:hover {
      opacity: 0.82;
      transform: translateY(-1px);
      border-color: rgba(25, 17, 24, 0.28);
    }

    .show-mobile {
      display: inline;
    }

    .hide-mobile {
      display: none;
    }

    .about-page .reveal {
      opacity: 1;
      transform: none;
    }

    .about-page.reveal-ready .reveal {
      opacity: 0;
      transform: translateY(18px);
      transition:
        opacity 0.72s cubic-bezier(0.2, 0.8, 0.2, 1),
        transform 0.72s cubic-bezier(0.2, 0.8, 0.2, 1);
      will-change: opacity, transform;
      -webkit-backface-visibility: hidden;
      backface-visibility: hidden;
    }

    .about-page.reveal-ready .reveal.is-inview {
      opacity: 1;
      transform: translateY(0);
      transition-delay: 0ms !important;
    }

    .about-collab .about-grid {
      align-items: stretch;
    }

    .about-collab .about-head {
      display: flex;
      flex-direction: column;
      justify-content: center;
      min-height: 100%;
    }

    .about-collab .about-head > * {
      margin-left: auto;
      margin-right: auto;
    }

    .about-signature {
      margin-top: 32px;
    }

    .signature-inner {
      display: grid;
      grid-template-columns: 0.9fr 1.1fr;
