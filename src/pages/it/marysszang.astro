  <script is:inline>
    function initMszFilters() {
      const filtersRoot = document.getElementById("filters");
      const grid = document.getElementById("artworks");
      const status = document.getElementById("filterStatus");
      if (!filtersRoot || !grid) return;

      const buttons = Array.from(filtersRoot.querySelectorAll("button[data-filter]"));
      const cards = Array.from(grid.querySelectorAll(".msz-card"));

      if (!buttons.length || !cards.length) return;

      const getLabelByKey = (key) => {
        const btn = buttons.find((b) => (b.dataset.filter || "all") === key);
        return btn ? btn.textContent.trim() : "Tutte";
      };

      const applyFilter = (key) => {
        let visibleCount = 0;

        cards.forEach((card) => {
          const show = key === "all" || card.classList.contains(key);
          card.style.display = show ? "" : "none";
          if (show) visibleCount++;
        });

        if (status) {
          const label = getLabelByKey(key);
          status.textContent = `${label} selezionata. Sono visibili ${visibleCount} opere.`;
        }
      };

      const setActiveButton = (activeBtn) => {
        buttons.forEach((b) => {
          const isActive = b === activeBtn;
          b.classList.toggle("active", isActive);
          b.setAttribute("aria-pressed", isActive ? "true" : "false");
        });
      };

      buttons.forEach((btn) => {
        btn.addEventListener("click", () => {
          const key = btn.dataset.filter || "all";
          setActiveButton(btn);
          applyFilter(key);
        });
      });

      const initial = buttons.find((b) => (b.dataset.filter || "all") === "all") || buttons[0];
      setActiveButton(initial);
      applyFilter("all");
    }

    document.addEventListener("DOMContentLoaded", initMszFilters);
    document.addEventListener("astro:page-load", initMszFilters);

    (() => {
      const btn = document.getElementById("goToTop");
      if (!btn) return;

      const toggle = () => {
        if (window.scrollY > 300) {
          btn.classList.add("is-visible");
        } else {
          btn.classList.remove("is-visible");
        }
      };

      btn.addEventListener("click", () => {
        window.scrollTo({ top: 0, behavior: "smooth" });
      });

      window.addEventListener("scroll", toggle, { passive: true });
      toggle();
    })();
  </script>
