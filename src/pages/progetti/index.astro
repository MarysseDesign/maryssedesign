---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const progetti = await getCollection("progetti");
progetti.sort((a, b) => (a.data.ordine ?? 999) - (b.data.ordine ?? 999));
---

<BaseLayout title="Projects" description="Selected projects and case studies." brand="marysse">
  <main class="container">
    <h1>Projects</h1>

    <div class="grid">
      {progetti.map((p) => (
        <a class="card" href={`/progetti/${p.slug}/`}>
          {p.data.cover && <img class="thumb" src={p.data.cover} alt={p.data.titolo} loading="lazy" />}
          <h2>{p.data.titolo}</h2>
          {p.data.abstract && <p>{p.data.abstract}</p>}
          {(p.data.cliente || p.data.anno) && (
            <small>{p.data.cliente}{p.data.cliente && p.data.anno ? " • " : ""}{p.data.anno}</small>
          )}
        </a>
      ))}
    </div>
  </main>
</BaseLayout>

<style>
  .container{max-width:980px;margin:0 auto;padding:48px 20px 90px;}
  .grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:18px;margin-top:26px;}
  .card{display:block;text-decoration:none;color:inherit;border:1px solid rgba(0,0,0,.12);border-radius:18px;overflow:hidden;background:#fff}
  .card:hover{border-color:rgba(0,0,0,.28)}
  .thumb{width:100%;height:180px;object-fit:cover;display:block;background:rgba(0,0,0,.04)}
  h2{margin:14px 16px 8px;font-size:18px}
  p{margin:0 16px 12px;opacity:.85;line-height:1.5}
  small{display:block;margin:0 16px 16px;opacity:.7}
</style>
