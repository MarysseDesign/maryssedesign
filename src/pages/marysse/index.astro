---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getCollection } from 'astro:content';
import ProjectCard from '@/components/ProjectCard.jsx';
const projects = await getCollection('progetti');
---
<BaseLayout brand="marysse" title="Marysse · Progetti">
  <section class="container space-y-8">
    <div class="grid md:grid-cols-2 gap-6" data-reveal>
      {projects.map(p => (
        <ProjectCard client:load
          href={`/marysse/progetti/${p.slug}/`}
          title={p.data.titolo}
          meta={`${p.data.cliente ?? ''}${p.data.anno ? ' · ' + p.data.anno : ''}`}
          poster={p.data.cover ?? '/placeholder.jpg'}
          video={p.data.video ?? null} />
      ))}
    </div>
  </section>
</BaseLayout>
