---
import BaseLayout from "@/layouts/BaseLayout.astro";
---
<BaseLayout brand="marysse" title="Servizi">
  <section class="container space-y-10">
    <header class="space-y-3" data-reveal>
      <p class="text-eyebrow uppercase tracking-wide text-gray-500">Cosa faccio</p>
      <h1 class="text-5xl md:text-6xl tracking-tightest font-semibold">Servizi</h1>
      <p class="text-sm text-gray-600">Dallo strategy al design fino alla produzione contenuti.</p>
    </header>
    <div class="grid md:grid-cols-3 gap-6" data-reveal>
      <div class="border border-gray-200 rounded-2xl p-6"><h3>Brand & Identity</h3></div>
      <div class="border border-gray-200 rounded-2xl p-6"><h3>Web & UI</h3></div>
      <div class="border border-gray-200 rounded-2xl p-6"><h3>Content & Social</h3></div>
    </div>
  </section>
</BaseLayout>
