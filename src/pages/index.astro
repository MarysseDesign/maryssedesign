---
import BaseLayout from "@/layouts/BaseLayout.astro";
import "../styles/services-dark-tarot.css";

const tarotServices = [
  {
    key: "branding",
    number: "I",
    title: "Branding",
    archetype: "The Signature",
    subtitle: "Identity & Positioning",
    img: "/images/tarot/branding.jpg",
    desc:
      "An identity and positioning crafted to feel inevitable, consistent and unmistakable across every touchpoint.",
  },
  {
    key: "strategy",
    number: "II",
    title: "Creative Direction",
    archetype: "The Visionary",
    subtitle: "Strategy & Creative Concept",
    img: "/images/tarot/strategy.jpg",
    desc:
      "Creative direction that shapes vision and meaning, guiding strategy, concepts and visual expression as one.",
  },
  {
    key: "advertising",
    number: "III",
    title: "Advertising",
    archetype: "The Allure",
    subtitle: "Campaigns & Art Direction",
    img: "/images/tarot/advertising.jpg",
    desc:
      "Campaigns designed with a refined eye, where art direction and visuals work together to express value and desire.",
  },
  {
    key: "web",
    number: "IV",
    title: "Web Design",
    archetype: "The Portal",
    subtitle: "Luxury Digital Experiences",
    img: "/images/tarot/web.jpg",
    desc:
      "Digital experiences crafted with clarity and precision, where structure, typography and motion feel effortless.",
  },
  {
    key: "storytelling",
    number: "V",
    title: "Storytelling",
    archetype: "The Voice",
    subtitle: "Narratives & Brand Voice",
    img: "/images/tarot/storytelling.jpg",
    desc:
      "Stories that sound authentic and intentional, shaping tone of voice and narratives that resonate over time.",
  },
  {
    key: "social",
    number: "VI",
    title: "Social Media",
    archetype: "The Pulse",
    subtitle: "Content & Editorial Rhythm",
    img: "/images/tarot/social.jpg",
    desc:
      "A considered social presence built through rhythm, content direction and visual consistency.",
  },
  {
    key: "visual",
    number: "VII",
    title: "Visual System",
    archetype: "The Code",
    subtitle: "Guidelines & Design Language",
    img: "/images/tarot/visual.jpg",
    desc:
      "A coherent visual system that defines rules, layouts and design language ready to evolve with the brand.",
  },
  {
    key: "photo",
    number: "VIII",
    title: "Photography",
    archetype: "The Gaze",
    subtitle: "Product & Brand Imagery",
    img: "/images/tarot/photo.jpg",
    desc:
      "Curated photography guided by art direction, shaping images that feel aligned, elevated and intentional.",
  },
  {
    key: "video",
    number: "IX",
    title: "Video",
    archetype: "The Motion",
    subtitle: "Motion & Brand Films",
    img: "/images/tarot/video.jpg",
    desc:
      "Motion and video content designed with cinematic sensitivity, from brand films to digital storytelling.",
  },
  {
    key: "events",
    number: "X",
    title: "Experiential",
    archetype: "The Encounter",
    subtitle: "Events & Brand Moments",
    img: "/images/tarot/events.jpg",
    desc:
      "Physical brand experiences shaped through identity, visuals and direction, translating the brand into space.",
  },
];

const collaborations = [
  { name: "Armani", src: "/images/collaborations/armani-beauty-logo.png",},
  { name: "Rinascente", src: "/images/collaborations/rinascente-logo.png",  },
  { name: "Mondadori", src: "/images/collaborations/mondadori-logo.png",  },
  { name: "Campari Academy", src: "/images/collaborations/campari-academy-logo.png", },
  { name:"Terrazza Aperol", src: "/images/collaborations/terrazza-aperol-logo.png",  },
  { name: "Berlucchi Franciacorta", src: "/images/collaborations/berlucchi-logo.png",  },
  { name: "The Wom", src: "/images/collaborations/the-wom-logo.png",  },
  { name: "My Personal Trainer", src: "/images/collaborations/my-personal-trainer-logo.png",  },
  { name: "My Personal Beauty", src: "/images/collaborations/my-personal-beauty-logo.png",  },
  { name: "L'Oreal", src: "/images/collaborations/loreal-logo.png",},
  { name: "Pupa", src: "/images/collaborations/pupa-logo.png",  },
  { name: "Primolino", src: "/images/collaborations/primolino-logo.png",  }
 
];

const selectedWorks = [
  {
    title: "Armani × Rinascente",
    category: "Retail Experience / Art Direction",
    href: "/projects/armani-rinascente/",
    image: "/images/projects/covers/home_Armani_Rinascente.jpg",
    alt: "Armani Rinascente project cover",
  },
  {
    title: "Campari Academy",
    category: "Brand Experience / Campaign",
    href: "/projects/campari/",
    image: "/images/projects/covers/03.png",
    alt: "Campari Academy project cover",
  },
  {
    title: "Primolino Milano",
    category: "Brand Identity / Packaging",
    href: "/projects/primolino/",
    image: "/images/projects/covers/11.Primolino.jpg",
    alt: "Primolino project cover",
  },
];
---

<BaseLayout
  brand="marysse"
  title="Marysse Design · Brand Boutique"
  noMainTopPadding={true}
  footerVariant="minimal"
>
  <div class="about-page home-marysse">
    <div class="starfield" aria-hidden="true">
      <div class="sky-glow"></div>
      <div class="stars stars--far"></div>
      <div class="stars stars--mid"></div>
      <div class="stars stars--near"></div>
      <div class="stars stars--bright"></div>
      <div class="vignette"></div>
    </div>

    <section class="tarot-hero" id="services">
      <div class="tarot-hero__wrap">
        <h1 class="tarot-hero__title">
          <span class="only-desktop">Pick a card, define your Brand.</span>
          <span class="only-mobile">Swipe the cards, define your Brand.</span>
        </h1>

        <p class="tarot-hero__sub only-desktop">
          Art direction & strategy, identity and visual worlds for contemporary brands.
        </p>

        <p class="tarot-hero__explain only-desktop">
          Each card represents a pillar of brand building, from positioning and visual identity to campaigns, digital presence and brand experience.
        </p>

        <p class="tarot-hint only-desktop">
          Drag to move. Draw a card. Click to reveal the details.
        </p>

        <p class="tarot-hero__sub only-mobile">
          Brand strategy, identity and visual worlds for contemporary brands.
        </p>

        <p class="tarot-hero__explain only-mobile">
          Each card reveals a different pillar of the brand universe. Tap one to explore the service.
        </p>

        <div class="tarot-actions">
          <button class="tarot-btn shuffle" type="button" id="tarotShuffle">
            Shuffle
          </button>
        </div>
      </div>

      <div class="tarot-stage-wrap" aria-hidden="false">
        <div class="tarot-stage" id="tarotStage" aria-label="Tarot services stage">
          {tarotServices.map((s, i) => (
            <article
              class="tarot-card"
              tabindex="0"
              role="button"
              aria-label={`${s.title} — open details`}
              data-key={s.key}
              data-number={s.number}
              data-title={s.title}
              data-subtitle={s.subtitle}
              data-archetype={s.archetype}
              data-img={s.img}
              data-desc={s.desc}
              style={`
                --x:${10 + (i * 8) % 80};
                --y:${58 + ((i % 3) * 10) - (i % 2 ? 6 : 0)};
                --r:${(i % 2 ? 10 : -10)}deg;
              `}
            >
              <div class="tarot-card__img">
                <img
                  src={s.img}
                  alt={`Tarot-inspired card for ${s.title}, ${s.subtitle}`}
                  loading={i < 2 ? "eager" : "lazy"}
                  decoding="async"
                />
              </div>

              <div class="tarot-card__meta">
                <div class="tarot-card__top">
                  <span class="tarot-card__mark">◆</span>
                  <span class="tarot-card__tag">{s.subtitle}</span>
                  <span class="tarot-card__mark">◆</span>
                </div>
                <h3 class="tarot-card__title">{s.title}</h3>
              </div>
            </article>
          ))}
        </div>
      </div>

      <div class="tarot-mobile" id="tarotMobile" aria-label="Services carousel">
        <div class="tarot-carousel" id="tarotCarousel">
          {tarotServices.map((s) => (
            <button
              class="tarot-slide"
              type="button"
              data-key={s.key}
              data-number={s.number}
              data-title={s.title}
              data-subtitle={s.subtitle}
              data-archetype={s.archetype}
              data-img={s.img}
              data-desc={s.desc}
              aria-label={`${s.title} — show details`}
            >
              <div class="tarot-slide__img">
                <img
                  src={s.img}
                  alt={`Tarot-inspired card for ${s.title}, ${s.subtitle}`}
                  loading="lazy"
                  decoding="async"
                />

                <div class="tarot-slide__card-meta" aria-hidden="true">
                  <p class="tarot-slide__card-number">{s.number}</p>
                  <p class="tarot-slide__card-archetype">{s.archetype}</p>
                </div>
              </div>

              <div class="tarot-slide__meta">
                <div class="tarot-slide__kicker">{s.subtitle}</div>
                <div class="tarot-slide__title">{s.title}</div>
              </div>
            </button>
          ))}
        </div>

        <div class="tarot-detail" id="tarotDetail" aria-live="polite">
          <p class="tarot-detail__kicker" id="tarotDetailKicker"></p>
          <h2 class="tarot-detail__title" id="tarotDetailTitle"></h2>
          <p class="tarot-detail__archetype" id="tarotDetailArchetype"></p>
          <p class="tarot-detail__text" id="tarotDetailText"></p>

          <div class="tarot-detail__actions">
            <a class="tarot-btn" id="tarotDetailMore" href="/services/">
              Explore the Service
            </a>
          </div>
        </div>
      </div>

      <div class="tarot-modal" id="tarotModal" hidden aria-hidden="true">
        <div class="tarot-modal__backdrop" data-close></div>

        <div
          class="tarot-modal__panel"
          role="dialog"
          aria-modal="true"
          aria-labelledby="tarotModalTitle"
          aria-describedby="tarotModalText"
        >
          <button
            class="tarot-modal__close"
            type="button"
            aria-label="Close"
            data-close
          >
            ✕
          </button>

          <div class="tarot-modal__grid">
            <div class="tarot-modal__media">
              <div class="tarot-modal__card-meta" aria-hidden="true">
                <p class="tarot-modal__card-number" id="tarotModalNumber"></p>
                <p class="tarot-modal__card-archetype" id="tarotModalArchetype"></p>
              </div>

              <img id="tarotModalImg" alt="" />
            </div>

            <div class="tarot-modal__content">
              <p class="tarot-modal__kicker" id="tarotModalKicker"></p>
              <h2 id="tarotModalTitle" class="tarot-modal__title"></h2>
              <p class="tarot-modal__text" id="tarotModalText"></p>

              <div class="tarot-modal__actions">
                <a class="tarot-btn" id="tarotModalMore" href="/services/">
                  Explore the Service
                </a>
                <button
                  class="tarot-btn tarot-btn--solid"
                  type="button"
                  id="tarotModalShuffle"
                >
                  Shuffle again
                </button>
              </div>
            </div>
          </div>
        </div>
      </div>

      <script src="../scripts/tarot-services.ts"></script>
    </section>

    <section
      class="md-home-section md-collaborations"
      id="collaborations"
      aria-labelledby="collab-title"
    >
      <div class="md-home-wrap">
        <div class="md-section-head">
          <p class="md-section-kicker">Selected collaborations</p>
          <h2 id="collab-title" class="md-section-title">
            Selected brands I’ve collaborated with
          </h2>
        </div>

      <div class="md-marquee-shell" aria-label="Collaborations logos marquee">
          <div class="md-marquee-track">
            {[...collaborations, ...collaborations].map((logo, index) => (
              <div
                class="md-logo-item"
                aria-hidden={index >= collaborations.length ? "true" : "false"}
              >
                <img
                  src={logo.src}
                  alt={logo.name}
                  loading="lazy"
                  decoding="async"
                  class="md-logo-image"
                />
              </div>
            ))}
          </div>
        </div>

        
      </div>

      </section>

<div class="md-divider"></div>

<section class="md-home-section md-collaborations">
      
    </section>

    <section class="md-home-section md-partners" aria-labelledby="partners-title">
  <div class="md-home-wrap">

    <div class="md-section-head">
      <p class="md-section-kicker">Creative network</p>

      <h2 id="partners-title" class="md-section-title">
        Agencies and collaborators
      </h2>
    </div>

    <div class="md-partners-grid md-partners-grid--desktop">
     <a href="https://www.canon.it/" target="_blank" rel="noopener">Canon</a>
      <a href="https://www.gruppomondadori.it//" target="_blank" rel="noopener">Gruppo Mondadori</a>
      <a href="https://www.uvetevents.com/it/" target="_blank" rel="noopener">Uvet Events</a>
      <a href="https://listenagency.com" target="_blank" rel="noopener">Listen Agency</a>
      <a href="https://nesscommunication.com/" target="_blank" rel="noopener">Ness Communication</a>
      <a href="https://dude.it" target="_blank" rel="noopener">Dude Milano</a>
      <a href="https://buzin.it" target="_blank" rel="noopener">Buzin Media Agency</a>
      <a href="https://motionstudio.it/" target="_blank" rel="noopener">Motion Studio</a>
      <a href="https://creativedeptstudio.com/creative-department-design" target="_blank" rel="noopener">Creative Department Design</a>
      <a href="https://www.ied.edu" target="_blank" rel="noopener">IED</a>
      <a href="https://www.naba.it" target="_blank" rel="noopener">NABA</a>
      <a href="https://www.accademiadellusso.com/" target="_blank" rel="noopener">Accademia del Lusso</a>
    </div>

    <div class="md-partners-inline" aria-label="Agencies and collaborators">
      <a href="https://www.canon.it/" target="_blank" rel="noopener">Canon</a>
      <span aria-hidden="true">•</span>
      <a href="https://www.gruppomondadori.it//" target="_blank" rel="noopener">Gruppo Mondadori</a>
      <span aria-hidden="true">•</span>
      <a href="https://www.uvetevents.com/it/" target="_blank" rel="noopener">Uvet Events</a>
      <span aria-hidden="true">•</span>
      <a href="https://listenagency.com" target="_blank" rel="noopener">Listen Agency</a>
      <span aria-hidden="true">•</span>
      <a href="https://nesscommunication.com/" target="_blank" rel="noopener">Ness Communication</a>
      <span aria-hidden="true">•</span>
      <a href="https://dude.it" target="_blank" rel="noopener">Dude Milano</a>
      <span aria-hidden="true">•</span>
     <span aria-hidden="true">•</span>
      <a href="https://buzin.it" target="_blank" rel="noopener">Buzin Media Agency</a>
      <span aria-hidden="true">•</span>
      <a href="https://motionstudio.it/" target="_blank" rel="noopener">Motion Studio</a>
      <span aria-hidden="true">•</span>
      <a href="https://creativedeptstudio.com/creative-department-design" target="_blank" rel="noopener">Creative Department Design</a>
       <a href="https://www.ied.edu" target="_blank" rel="noopener">IED</a>
      <span aria-hidden="true">•</span>
      <a href="https://www.naba.it" target="_blank" rel="noopener">NABA</a>
      <span aria-hidden="true">•</span>
      <a href="https://www.accademiadellusso.com/" target="_blank" rel="noopener">Accademia del Lusso</a>
    </div>

  </div>
</section>
    
</section>

<div class="md-divider"></div>

<section class="md-home-section md-collaborations">

    <section
      class="md-home-section md-selected-work"
      id="selected-work"
      aria-labelledby="selected-work-title"
    >
      <div class="md-home-wrap">
        <div class="md-section-head md-section-head--work">
          <p class="md-section-kicker">Selected work</p>
          <h2 id="selected-work-title" class="md-section-title">
            A curated selection of projects across retail, experience and brand identity.
          </h2>
        </div>

        <div class="md-work-grid">
          {selectedWorks.map((project, index) => (
            <a
              class="md-work-card md-work-card--visual"
              href={project.href}
              aria-label={`Open project ${project.title}`}
            >
              <div class="md-work-card__visual">
                <img
                  src={project.image}
                  alt={project.alt}
                  loading="lazy"
                  decoding="async"
                />
              </div>

              <div class="md-work-card__content">
                <p class="md-work-card__index">{String(index + 1).padStart(2, "0")}</p>
                <p class="md-work-card__category">{project.category}</p>
                <h3 class="md-work-card__title">{project.title}</h3>
                <span class="md-work-card__link">View project</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="md-home-section md-bottom-cta" aria-labelledby="md-bottom-cta-title">
      <div class="md-bottom-cta__inner">
        <div class="tarot-foundation md-bottom-cta__foundation">
          <p id="md-bottom-cta-title" class="tarot-foundation__text">
            Marysse Design is the brand boutique founded by Maria Assunta Zangone,
            art director and visual artist based in Milan.
          </p>
        </div>

       <div class="tarot-continue md-home-continue md-home-continue--bottom">
  <a class="tarot-btn tarot-btn--solid" href="/about/">
    Discover the studio
  </a>

  <a class="tarot-btn shuffle" href="/projects/">
    Explore the work
  </a>
</div>
  

</div>
      </div>
    </section>
  </div>
</BaseLayout>