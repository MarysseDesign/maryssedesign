const getAlt = (src, title) => altBySrc[src] ?? `${title} — digital artwork by Marysszang`;
---

<BaseLayout brand="marysszang" title="Marysszang · Artworks">
  <style is:inline>
    /* ✅ Accessibilità: testo solo screen reader */
    .sr-only {
      position: absolute;
      width: 1px;
      height: 1px;
      padding: 0;
      margin: -1px;
      overflow: hidden;
      clip: rect(0, 0, 0, 0);
      white-space: nowrap;
      border: 0;
    }
  </style>

  <!-- HERO -->
  <section class="msz-hero" aria-labelledby="msz-title">
    <!-- HERO TITLE -->
    <h1 class="msz-title typewriter" id="msz-title" data-text={pageTitle}>
      <!-- ✅ SR vede il titolo, visivamente resta il typewriter -->
      <span class="sr-only">{pageTitle}</span>
      <span aria-hidden="true">{pageTitle}</span>
    </h1>

    <p class="msz-subtitle">
      As you move through this page, you’ll discover my soul as a digital artist. <br class="hide-on-mobile" />
      A language of softness and balance.<br class="hide-on-mobile" />
      An invitation to breathe, to feel, to see light.<br class="hide-on-mobile" />
      <br />
      <a
        href="https://www.instagram.com/marysszang"
        target="_blank"
        rel="noopener noreferrer"
        class="msz-ig"
        aria-label="Open @marysszang on Instagram (opens in a new tab)"
      >
        @marysszang
      </a>
    </p>

    <!-- ✅ Annuncio cambio filtro -->
    <p id="filterStatus" class="sr-only" aria-live="polite"></p>

    <ul class="msz-filters" id="filters" aria-label="Filter artworks">
      {filterDefs.map((f) => (
        <li>
          <button
            type="button"
            class={"msz-chip " + (f.key === "all" ? "active" : "")}
            data-filter={f.key}
            aria-controls="artworks"
            aria-pressed={f.key === "all" ? "true" : "false"}
          >
            {f.label}
          </button>
        </li>
      ))}
    </ul>
  </section>

  <!-- GRIGLIA artworks -->
  <section class="msz-grid" id="artworks" aria-label="Artworks grid">
    {items.map((it) => (
      <figure class={"msz-card " + it.filterKey} data-filterkey={it.filterKey}>
        <img
          loading="lazy"
          decoding="async"
          src={it.src}
          alt={getAlt(it.src, it.title)}
        />
        <figcaption>
          <strong>{it.title}</strong>
          <span>{it.collection}</span>
        </figcaption>
      </figure>
    ))}
  </section>

  <!-- ABOUT -->
  <section class="msz-about" id="about" aria-labelledby="about-title">
    <div class="msz-about-inner">
      <h2 id="about-title">About Marysszang</h2>

      <p>
        Marysszang is my visual space, a dialogue between lightness and emotion.
        <br class="hide-on-mobile" />
        Every creation begins with a fleeting thought, a subtle detail, a silent reflection —
        transformed into a story made of images.
        Through photography and visual storytelling, I explore the beauty of simplicity,
        <br class="hide-on-mobile" />
        the poetry of everyday life, and the subtle balance between imagination and reality.
      </p>

      <p>
        My creative language flows between softness and surreality, inspired by textures, natural light,
        and the quiet rhythm of time. Marysszang is not just a project, it’s an evolving vision,
        <br class="hide-on-mobile" />
        a way to shape emotions and share calm and wonder.
      </p>

      <a
        href="https://www.instagram.com/marysszang"
        target="_blank"
        rel="noopener noreferrer"
        class="msz-ig"
        aria-label="Open @marysszang on Instagram (opens in a new tab)"
      >
        @marysszang
      </a>
    </div>

    <!-- About image -->
    <figure class="msz-about-figure">
      <img
        src="/images/about/marysszang-portrait.jpg"
        alt="Marysszang — surreal minimalist portrait"
        loading="lazy"
        decoding="async"
        width="768"
        height="910"
