---
import "@/styles/tailwind.css";
import "@/styles/global.css";
import "@/styles/header.css";

import Header from "@/components/Header.astro";
import SiteHeaderMarysszang from "@/components/SiteHeader.astro";
import Footer from "@/components/Footer.astro";
import CookieBanner from "@/components/CookieBanner.astro";

import { getLangFromUrl } from "@/lib/i18n";

type FooterVariant = "default" | "minimal";

interface Props {
  brand?: "marysse" | "marysszang";
  title?: string;
  description?: string;
  lang?: string;
  ogImage?: string;
  noMainBottomPadding?: boolean;
  footerVariant?: FooterVariant;
  noMainTopPadding?: boolean;
}

const {
  brand = "marysse",
  title = "Marysse Design — Brand Boutique",
  description = "Creative direction, brand identity and visual culture.",
  lang: langProp,
  ogImage = "/og-image.jpg",
  noMainBottomPadding = false,
  footerVariant = "default",
  noMainTopPadding = false,
} = Astro.props;

const lang = langProp ?? getLangFromUrl(Astro.url);
const isIt = lang === "it";

const origin = (Astro.site ?? Astro.url.origin) as string;
const canonicalURL = new URL(Astro.url.pathname, origin).toString();

const absoluteOgImage = ogImage.startsWith("http")
  ? ogImage
  : new URL(ogImage, origin).toString();

const ogLocale = isIt ? "it_IT" : "en_US";
---

<html lang={lang}>
  <head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />

  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="robots" content="index,follow" />

  <link rel="canonical" href={canonicalURL} />
  <meta property="og:locale" content={ogLocale} />
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="Marysse Design" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={absoluteOgImage} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:url" content={canonicalURL} />

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={absoluteOgImage} />

  <slot name="head" />

  <link rel="icon" href="/favicon.ico" sizes="any" />
  <link rel="icon" type="image/png" sizes="32x32" href="/m_favicon-32.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/m_favicon-16.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

  <script
    type="application/ld+json"
    set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "CreativeAgency",
      name: "Marysse Design",
      url: "https://maryssedesign.com",
      logo: "https://maryssedesign.com/images/Marysse_logo_footer.png",
      description: isIt
        ? "Brand boutique specializzata in direzione creativa, brand identity e cultura visiva."
        : "Brand boutique focused on creative direction, brand identity and visual culture.",
      sameAs: [
        "https://www.instagram.com/maryssedesign/",
        "https://www.instagram.com/marysszang/"
      ],
      founder: {
        "@type": "Person",
        name: "Maria Assunta Zangone",
        jobTitle: isIt ? "Art Director e Visual Artist" : "Art Director & Visual Artist",
      },
    })}
  />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Noto+Serif+Display:wght@100;300;400;700&display=swap"
    rel="stylesheet"
  />
  <link
    href="https://fonts.googleapis.com/css2?family=Heebo:wght@100;200;300;400;500;600&display=swap"
    rel="stylesheet"
  />
</head>
  <body
    class="min-h-screen bg-white text-gray-900 font-sans text-base font-light"
    data-footer-variant={footerVariant}
  >
    {brand === "marysszang"
      ? <SiteHeaderMarysszang lang={lang} />
      : <Header brand={brand} lang={lang} />}

    <CookieBanner GA_ID={import.meta.env.PUBLIC_GA_ID ?? ""} lang={lang} />

    <main
      style={`padding-top: ${noMainTopPadding ? "0px" : "var(--header-h, 80px)"}`}
      class={`${noMainBottomPadding ? "pb-0" : "pb-24"}`}
    >
      <slot />
    </main>

    {footerVariant === "minimal" ? (
  <footer data-footer-variant="minimal" class="bg-[#120b10] text-white/70">
    <div class="max-w-6xl mx-auto px-6 py-16 text-center">
      <img
        src="/images/Marysse_logo_footer.png"
        alt="Marysse Design"
        class="mx-auto h-10 w-auto opacity-90"
        loading="lazy"
        decoding="async"
      />
      <p class="mt-6 text-[11px] tracking-[0.22em] uppercase opacity-70">
        BY MARIA ASSUNTA ZANGONE
      </p>

      <p class="mt-6 text-[11px] tracking-[0.22em] uppercase opacity-50">
        © MARYSSE DESIGN 2026 | P. IVA: 13993600967 |
        {isIt
          ? " SEDE LEGALE: VIA LOMELLINA 12, MILANO (MI) ITALIA"
          : " REGISTERED OFFICE: VIA LOMELLINA 12, MILAN (MI) ITALY"}
      </p>

      <div class="mt-8 flex items-center justify-center gap-6 text-[11px] tracking-[0.22em] uppercase">
        <a class="opacity-70 hover:opacity-100 transition" href={isIt ? "/it/privacy" : "/privacy"}>
          Privacy Policy
        </a>
        <span class="opacity-40">|</span>
        <a class="opacity-70 hover:opacity-100 transition" href={isIt ? "/it/cookie-policy" : "/cookie-policy"}>
          Cookie Policy
        </a>
      </div>
    </div>
  </footer>
) : (
  <Footer lang={lang} />
)}

    <script defer src="/js/smooth-scroll.js"></script>
    <script defer src="/js/monogram-cursor.js"></script>

    <script is:inline>
      (() => {
        const els = document.querySelectorAll('.reveal, .reveal-media, .reveal-line');
        if (!('IntersectionObserver' in window) || !els.length) {
          els.forEach(el => el.classList.add('is-inview'));
          return;
        }

        const io = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (!entry.isIntersecting) return;
            const el = entry.target;
            const d = el.getAttribute('data-delay');
            if (d) el.style.setProperty('--delay', `${d}ms`);
            el.classList.add('is-inview');
            io.unobserve(el);
          });
        }, {
          threshold: 0.12,
          rootMargin: '0px 0px -10% 0px'
        });

        els.forEach(el => io.observe(el));
      })();
    </script>

    <script is:inline>
      (() => {
        const normalize = (p) => {
          if (!p) return "/";
          const clean = p.split("?")[0].split("#")[0];
          return clean.length > 1 ? clean.replace(/\/+$/, "") : "/";
        };

        const path = normalize(window.location.pathname);
        const links = document.querySelectorAll("header nav a[href^='/']");
        if (!links.length) return;

        let bestMatch = null;
        let bestLen = -1;

        links.forEach((a) => {
          const href = normalize(a.getAttribute("href") || "/");
          const isMatch = href === path || (href !== "/" && path.startsWith(href + "/"));
          if (!isMatch) return;

          if (href.length > bestLen) {
            bestLen = href.length;
            bestMatch = a;
          }
        });

        if (bestMatch) bestMatch.classList.add("is-active");
      })();
    </script>

    <style is:global>
      header nav a.is-active {
        color: var(--ink);
        position: relative;
      }

      header nav a.is-active::after {
        content: "";
        position: absolute;
        left: 50%;
        bottom: -6px;
        width: 4px;
        height: 4px;
        border-radius: 999px;
        background: var(--ink);
        transform: translateX(-50%);
        opacity: 0.9;
      }
    </style>
  </body>
</html>